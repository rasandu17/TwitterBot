{
  "version": 2,
  "name": "twitter-video-bot",
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/webhook.py"
    }
  ],
  "env": {
    "TELEGRAM_BOT_TOKEN": "@telegram_bot_token"
  },
  "functions": {
    "api/webhook.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
